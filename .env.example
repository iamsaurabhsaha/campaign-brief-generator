# ── LLM Provider Configuration ──────────────────────────────────────────────
# Choose your provider: anthropic | openai | azure | gemini | bedrock | ollama
LLM_PROVIDER=anthropic

# Model name (optional — defaults to a sensible model per provider)
# Anthropic:  claude-sonnet-4-20250514, claude-opus-4-20250514, claude-haiku-4-5-20251001
# OpenAI:     gpt-4o, gpt-4o-mini, o3-mini
# Azure:      your deployment name (e.g. gpt-4o)
# Gemini:     gemini-2.5-pro, gemini-2.5-flash
# Bedrock:    anthropic.claude-sonnet-4-20250514-v1:0
# Ollama:     llama3.1, mistral, etc.
# LLM_MODEL=claude-sonnet-4-20250514

# ── API Keys (set only the one for your chosen provider) ────────────────────
ANTHROPIC_API_KEY=your_api_key_here
# OPENAI_API_KEY=your_api_key_here
# GOOGLE_API_KEY=your_api_key_here

# ── Azure OpenAI (only if LLM_PROVIDER=azure) ──────────────────────────────
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-10-21

# ── AWS Bedrock (only if LLM_PROVIDER=bedrock) ─────────────────────────────
# Uses AWS credentials from environment or IAM role
# AWS_REGION=us-east-1

# ── Ollama (only if LLM_PROVIDER=ollama) ────────────────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434

# ── Custom OpenAI-compatible endpoint ───────────────────────────────────────
# Use with LLM_PROVIDER=openai to point to Groq, Together AI, Mistral, etc.
# LLM_BASE_URL=https://api.groq.com/openai/v1
